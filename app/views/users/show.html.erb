<div class="container mt-4">
  <div class="row">
    <div class="col-md-4">
      <!-- Боковая панель с информацией о пользователе -->
      <div class="card">
        <div class="card-body text-center">
          <% if @user.avatar.present? %>
            <%= image_tag @user.avatar.url, class: 'rounded-circle mb-3', style: 'width: 150px; height: 150px; object-fit: cover;' %>
          <% else %>
            <div class="bg-secondary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 150px; height: 150px;">
              <span class="text-white fs-1"><%= @user.email[0].upcase %></span>
            </div>
          <% end %>
          
          <h4><%= @user.email %></h4>
          
          <div class="d-flex justify-content-around mt-3">
            <div class="text-center">
              <h5 class="mb-0"><%= @posts.count %></h5>
              <small class="text-muted">Posts</small>
            </div>
            <div class="text-center">
              <h5 class="mb-0"><%= @user.followers.count %></h5>
              <small class="text-muted">Followers</small>
            </div>
            <div class="text-center">
              <h5 class="mb-0"><%= @user.following.count %></h5>
              <small class="text-muted">Following</small>
            </div>
          </div>
          
          <% if user_signed_in? && current_user != @user %>
            <div class="mt-3">
              <% if current_user.following?(@user) %>
                <%= button_to 'Unfollow', unfollow_user_path(@user), method: :post, class: 'btn btn-danger btn-sm' %>
              <% else %>
                <%= button_to 'Follow', follow_user_path(@user), method: :post, class: 'btn btn-primary btn-sm' %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
    
    <div class="col-md-8">
      <!-- Посты пользователя -->
      <h4 class="mb-4">Posts</h4>
      
      <% if @posts.any? %>
        <div class="row">
          <% @posts.each do |post| %>
            <div class="col-md-6 col-lg-4 mb-4">
              <div class="card">
                <%= link_to post do %>
                  <%= image_tag post.image.thumb.url, class: 'card-img-top', style: 'height: 200px; object-fit: cover;' %>
                <% end %>
                
                <div class="card-body">
                  <p class="card-text"><%= truncate(post.caption, length: 100) %></p>
                  <small class="text-muted"><%= time_ago_in_words(post.created_at) %> ago</small>
                  
                  <div class="mt-2">
                    <% if user_signed_in? %>
                      <% if current_user.liked_posts.include?(post) %>
                        <%= button_to 'Unlike', unlike_post_path(post), method: :post, class: 'btn btn-sm btn-danger' %>
                      <% else %>
                        <%= button_to 'Like', like_post_path(post), method: :post, class: 'btn btn-sm btn-primary' %>
                      <% end %>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
        
        <!-- Пагинация -->
        <% if @posts.respond_to?(:total_pages) %>
          <div class="d-flex justify-content-center mt-4">
            <%= paginate @posts %>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-5">
          <h5 class="text-muted">No posts yet</h5>
          <% if user_signed_in? && current_user == @user %>
            <%= link_to 'Create your first post', new_post_path, class: 'btn btn-primary mt-2' %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>
