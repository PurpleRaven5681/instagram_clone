<h1 class="mb-4">Edit Post</h1>

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card">
      <div class="card-body">
        <%= render 'form', post: @post %>
      </div>
    </div>
    
    <div class="mt-3">
      <%= link_to 'Show Post', @post, class: 'btn btn-info me-2' %>
      <%= link_to 'Back to Posts', posts_path, class: 'btn btn-secondary' %>
    </div>
  </div>
</div>
