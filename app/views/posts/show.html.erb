<div class="row justify-content-center">
  <div class="col-md-8 col-lg-6">
    <div class="card">
      <%= image_tag @post.image.url, class: 'card-img-top' %>
      
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h5 class="card-title mb-0">
            <%= link_to @post.user.email, user_path(@post.user), class: 'text-decoration-none text-dark' %>
          </h5>
          
          <% if user_signed_in? %>
            <div>
              <% if current_user.liked_posts.include?(@post) %>
                <%= button_to 'Unlike', unlike_post_path(@post), method: :post, class: 'btn btn-sm btn-danger' %>
              <% else %>
                <%= button_to 'Like', like_post_path(@post), method: :post, class: 'btn btn-sm btn-primary' %>
              <% end %>
            </div>
          <% end %>
        </div>
        
        <p class="card-text"><%= @post.caption %></p>
        
        <div class="d-flex justify-content-between align-items-center">
          <small class="text-muted"><%= time_ago_in_words(@post.created_at) %> ago</small>
          
          <% if user_signed_in? && current_user == @post.user %>
            <div>
              <%= link_to 'Edit', edit_post_path(@post), class: 'btn btn-sm btn-outline-primary me-2' %>
              <%= button_to 'Delete', post_path(@post), 
                          method: :delete, 
                          data: { confirm: 'Are you sure?' }, 
                          class: 'btn btn-sm btn-outline-danger' %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
    
    <div class="mt-3">
      <%= link_to 'Back to Posts', posts_path, class: 'btn btn-secondary' %>
    </div>
  </div>
</div>
