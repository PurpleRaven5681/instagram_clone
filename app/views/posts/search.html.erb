<h1>Search Posts</h1>

<%= search_form_for @q, url: search_posts_path do |f| %>
  <div class="input-group mb-3">
    <%= f.search_field :caption_cont, class: 'form-control', placeholder: 'Search posts...' %>
    <%= f.submit 'Search', class: 'btn btn-primary' %>
  </div>
<% end %>

<% if @posts.any? %>
  <div class="row">
    <% @posts.each do |post| %>
      <div class="col-md-4 mb-3">
        <div class="card">
          <%= link_to post do %>
            <%= image_tag post.image.thumb.url, class: 'card-img-top' %>
          <% end %>
          <div class="card-body">
            <p class="card-text"><%= truncate(post.caption, length: 100) %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  
  <%= paginate @posts %>
<% else %>
  <p>No posts found.</p>
<% end %>
